{
  "name": "dyvix-ui",
  "version": "0.0.8-alpha.2",
  "description": "Dyvix is an open source, modern, config-driven, animated component UI library. Beautiful by default, customizable by design.",
  "main": "src/index.jsx",
  "type": "module",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.0",
    "vitepress": "^1.6.4"
  },
  "keywords": [
    "react",
    "ui-kit",
    "config",
    "gsap",
    "animation",
    "components",
    "ui-library"
  ],
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.14.2"
  },
  "scripts": {
    "format": "prettier --write . --ignore-path .gitignore",
    "lint": "eslint \"**/*.{js,jsx}\"",
    "prebuild": "npm run dyvix:build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dyvix:build": "node dev-engine/scripts/generate-constants.js"
  }
}
